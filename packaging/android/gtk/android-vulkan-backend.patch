+#pragma once
+
+#include "gdkconfig.h"
+
+#ifdef GDK_RENDERING_VULKAN
+
+#define VK_USE_PLATFORM_ANDROID_KHR
+
+#include "gdkvulkancontextprivate.h"
+
+G_BEGIN_DECLS
+
+#define GDK_TYPE_ANDROID_VULKAN_CONTEXT     (gdk_android_vulkan_context_get_type ())
+#define GDK_ANDROID_VULKAN_CONTEXT(obj)     (G_TYPE_CHECK_INSTANCE_CAST ((obj), GDK_TYPE_ANDROID_VULKAN_CONTEXT, GdkAndroidVulkanContext))
+#define GDK_IS_ANDROID_VULKAN_CONTEXT(obj)  (G_TYPE_CHECK_INSTANCE_TYPE ((obj), GDK_TYPE_ANDROID_VULKAN_CONTEXT))
+
+typedef struct _GdkAndroidVulkanContext GdkAndroidVulkanContext;
+typedef struct _GdkAndroidVulkanContextClass GdkAndroidVulkanContextClass;
+
+struct _GdkAndroidVulkanContext
+{
+  GdkVulkanContext parent_instance;
+};
+
+struct _GdkAndroidVulkanContextClass
+{
+  GdkVulkanContextClass parent_class;
+};
+
+GType gdk_android_vulkan_context_get_type (void) G_GNUC_CONST;
