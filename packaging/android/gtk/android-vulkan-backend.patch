diff --git a/gdk/android/gdkandroidvulkancontext.c b/gdk/android/gdkandroidvulkancontext.c
new file mode 100644
index 0000000..a12b371
--- /dev/null
+++ b/gdk/android/gdkandroidvulkancontext.c
@@ -0,0 +1,82 @@
+/*
+ * Copyright (c) 2026 Anton Politov
+ *
+ * This library is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
+ * License as published by the Free Software Foundation; either
+ * version 2.1 of the License, or (at your option) any later version.
+ *
+ * This library is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * Lesser General Public License for more details.
+ *
+ * You should have received a copy of the GNU Lesser General Public
+ * License along with this library. If not, see <http://www.gnu.org/licenses/>.
+ *
+ * SPDX-License-Identifier: LGPL-2.1-or-later
+ */
+
+#include "config.h"
+
+#include "gdkconfig.h"
+
+#ifdef GDK_RENDERING_VULKAN
+
+#include "gdkandroidvulkancontext-private.h"
+
+#include "gdkandroidsurface-private.h"
+
+G_DEFINE_TYPE (GdkAndroidVulkanContext, gdk_android_vulkan_context, GDK_TYPE_VULKAN_CONTEXT)
+
+static VkResult
+gdk_android_vulkan_context_create_surface (GdkVulkanContext *context,
+                                           VkSurfaceKHR     *vr_surface)
+{
+  GdkSurface *surface = gdk_draw_context_get_surface (GDK_DRAW_CONTEXT (context));
+  GdkAndroidSurface *android_surface = GDK_ANDROID_SURFACE (surface);
+  VkResult res;
+
+  /* The ANativeWindow is (re)bound on visibility changes from the UI thread; hold
+   * the same lock the surface uses while we hand it to Vulkan. */
+  g_mutex_lock (&android_surface->native_lock);
+
+  if (android_surface->native == NULL)
+    {
+      /* No native window bound (surface detached, e.g. while backgrounded). This
+       * is expected and transient, so it is not a warning: surface-lost makes the
+       * renderer retry once the window is reattached. */
+      GDK_DEBUG (VULKAN, "no ANativeWindow bound, reporting VK_ERROR_SURFACE_LOST_KHR");
+      g_mutex_unlock (&android_surface->native_lock);
+      return VK_ERROR_SURFACE_LOST_KHR;
+    }
+
+  res = GDK_VK_CHECK (vkCreateAndroidSurfaceKHR, gdk_vulkan_context_get_instance (context),
+                                                 &(VkAndroidSurfaceCreateInfoKHR) {
+                                                     .sType = VK_STRUCTURE_TYPE_ANDROID_SURFACE_CREATE_INFO_KHR,
+                                                     .pNext = NULL,
+                                                     .flags = 0,
+                                                     .window = android_surface->native
+                                                 },
+                                                 NULL,
+                                                 vr_surface);
+
+  g_mutex_unlock (&android_surface->native_lock);
+
+  return res;
+}
+
+static void
+gdk_android_vulkan_context_class_init (GdkAndroidVulkanContextClass *klass)
+{
+  GdkVulkanContextClass *vulkan_context_class = GDK_VULKAN_CONTEXT_CLASS (klass);
+
+  vulkan_context_class->create_surface = gdk_android_vulkan_context_create_surface;
+}
+
+static void
+gdk_android_vulkan_context_init (GdkAndroidVulkanContext *self)
+{
+}
+
+#endif /* GDK_RENDERING_VULKAN */
