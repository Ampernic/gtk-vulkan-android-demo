From ba90d5bef88cedead10eaf6320a2e8e53d3d460f Mon Sep 17 00:00:00 2001
From: Ampernic <ampernic@inbox.ru>
Date: Mon, 15 Jun 2026 15:22:53 +0300
Subject: [PATCH] gdk/android: add a Vulkan WSI backend
 (GdkAndroidVulkanContext)

gdk-android only provided a GL context, so GTK always fell back to the GL
renderer on Android even on hardware with full Vulkan support. Add a
GdkVulkanContext implementation whose create_surface builds a VkSurfaceKHR
from the surface's ANativeWindow via vkCreateAndroidSurfaceKHR, and wire it
into GdkAndroidDisplay (vk_context_type + VK_KHR_android_surface instance
extension). The generic GdkVulkanContext drives swapchain/present. Guarded
by GDK_RENDERING_VULKAN; the GL path is unchanged when Vulkan is off or the
surface has no native window yet (returns VK_ERROR_SURFACE_LOST_KHR).
---
 gdk/android/gdkandroiddisplay.c               | 12 +++
 gdk/android/gdkandroidvulkancontext-private.h | 53 +++++++++++++
 gdk/android/gdkandroidvulkancontext.c         | 82 +++++++++++++++++++
 gdk/android/meson.build                       |  1 +
 4 files changed, 148 insertions(+)
 create mode 100644 gdk/android/gdkandroidvulkancontext-private.h
 create mode 100644 gdk/android/gdkandroidvulkancontext.c

diff --git a/gdk/android/gdkandroiddisplay.c b/gdk/android/gdkandroiddisplay.c
index 74df7fa..69ed117 100644
--- a/gdk/android/gdkandroiddisplay.c
+++ b/gdk/android/gdkandroiddisplay.c
@@ -19,6 +19,10 @@
 
 #include "config.h"
 
+/* Expose VK_KHR_android_surface (vulkan_android.h) before any header pulls in
+ * vulkan.h, so VK_KHR_ANDROID_SURFACE_EXTENSION_NAME is available below. */
+#define VK_USE_PLATFORM_ANDROID_KHR
+
 #include "gdkdisplayprivate.h"
 #include "gdkeventsprivate.h"
 #include "gdkframeclockprivate.h"
@@ -34,6 +38,9 @@
 #include "gdkandroiddevice-private.h"
 #include "gdkandroidkeymap-private.h"
 #include "gdkandroidglcontext-private.h"
+#ifdef GDK_RENDERING_VULKAN
+#include "gdkandroidvulkancontext-private.h"
+#endif
 
 #include "gdkandroiddisplay-private.h"
 
@@ -255,8 +262,13 @@ gdk_android_display_class_init (GdkAndroidDisplayClass *klass)
   display_class->toplevel_type = GDK_TYPE_ANDROID_TOPLEVEL;
   display_class->popup_type = GDK_TYPE_ANDROID_POPUP;
   display_class->cairo_context_type = GDK_TYPE_ANDROID_CAIRO_CONTEXT;
+#ifdef GDK_RENDERING_VULKAN
+  display_class->vk_context_type = GDK_TYPE_ANDROID_VULKAN_CONTEXT;
+  display_class->vk_extension_name = VK_KHR_ANDROID_SURFACE_EXTENSION_NAME;
+#else
   display_class->vk_context_type = G_TYPE_NONE;
   display_class->vk_extension_name = NULL;
+#endif
 
   display_class->get_name = gdk_android_display_get_name;
   display_class->beep = gdk_android_display_beep;
