From 631d4d7eb488ceaa98d7eb86f7fa0ac194ec0cfd Mon Sep 17 00:00:00 2001
From: Ampernic <ampernic@inbox.ru>
Date: Mon, 15 Jun 2026 11:12:01 +0300
Subject: [PATCH 1/2] gdk/android: read input events via JNI so the backend
 works below API 31

AMotionEvent_fromJava/AKeyEvent_fromJava/AInputEvent_release are
__INTRODUCED_IN(31); below 31 read the event via JNI from the Java
MotionEvent/KeyEvent instead. Also make the JNI refcache tolerant of
classes/methods/fields absent on older APIs (clear the pending exception
and leave the cached id NULL) so init does not abort the VM on, e.g.,
android.graphics.BlendMode (API 29), which the backend never calls.
---
 gdk/android/gdkandroidevents-private.h |  29 +++
 gdk/android/gdkandroidevents.c         | 244 +++++++++++++++++++++----
 gdk/android/gdkandroidinit-private.h   |  25 +++
 gdk/android/gdkandroidinit.c           | 135 ++++++++++++--
 gdk/android/gdkandroidseat-private.h   |   6 +-
 gdk/android/gdkandroidseat.c           |  12 +-
 6 files changed, 385 insertions(+), 66 deletions(-)

diff --git a/gdk/android/gdkandroidevents-private.h b/gdk/android/gdkandroidevents-private.h
index c685b1a..39e2963 100644
--- a/gdk/android/gdkandroidevents-private.h
+++ b/gdk/android/gdkandroidevents-private.h
@@ -19,10 +19,39 @@
 
 #pragma once
 
+#include <android/input.h>
+
 #include "gdkandroidsurface-private.h"
 
 G_BEGIN_DECLS
 
+typedef struct
+{
+  const AInputEvent *native;  /* non-NULL only on API >= 31 (from *_fromJava) */
+  JNIEnv            *env;
+  jobject            jevent;  /* the Java MotionEvent / KeyEvent */
+} GdkAndroidInputEvent;
+
+gint32 gdk_android_input_get_source (const GdkAndroidInputEvent *e);
+gint32 gdk_android_input_get_device_id (const GdkAndroidInputEvent *e);
+
+gint32 gdk_android_motion_get_action (const GdkAndroidInputEvent *e);
+gint32 gdk_android_motion_get_meta_state (const GdkAndroidInputEvent *e);
+size_t gdk_android_motion_get_pointer_count (const GdkAndroidInputEvent *e);
+gint32 gdk_android_motion_get_pointer_id (const GdkAndroidInputEvent *e, size_t pointer_index);
+gfloat gdk_android_motion_get_x (const GdkAndroidInputEvent *e, size_t pointer_index);
+gfloat gdk_android_motion_get_y (const GdkAndroidInputEvent *e, size_t pointer_index);
+gint32 gdk_android_motion_get_tool_type (const GdkAndroidInputEvent *e, size_t pointer_index);
+gint32 gdk_android_motion_get_button_state (const GdkAndroidInputEvent *e);
+gfloat gdk_android_motion_get_axis_value (const GdkAndroidInputEvent *e, gint32 axis, size_t pointer_index);
+gint64 gdk_android_motion_get_event_time_ns (const GdkAndroidInputEvent *e);
+gint64 gdk_android_motion_get_down_time_ns (const GdkAndroidInputEvent *e);
+
+gint32 gdk_android_key_get_action (const GdkAndroidInputEvent *e);
+gint32 gdk_android_key_get_meta_state (const GdkAndroidInputEvent *e);
+gint32 gdk_android_key_get_key_code (const GdkAndroidInputEvent *e);
+gint64 gdk_android_key_get_event_time_ns (const GdkAndroidInputEvent *e);
+
 void gdk_android_events_handle_motion_event (GdkAndroidSurface *surface, jobject motion_event, jint event_identifier);
 void gdk_android_events_handle_key_event (GdkAndroidSurface *surface, jobject key_event);
 
