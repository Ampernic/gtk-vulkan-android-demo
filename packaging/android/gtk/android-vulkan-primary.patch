From afa0f9075d40979058dfc03a405a627919287665 Mon Sep 17 00:00:00 2001
From: Ampernic <ampernic@inbox.ru>
Date: Mon, 15 Jun 2026 15:53:20 +0300
Subject: [PATCH] gsk: allow Vulkan as the primary renderer on Android

vulkan_supported_platform() only offered Vulkan as the primary renderer on
Wayland; everywhere else it was fallback-only, so Android always used GL
even with a working Vulkan backend. Android always composites and presents
through a single backend surface (like Wayland), so allow Vulkan to be
chosen as the primary renderer there too.
---
 gsk/gskrenderer.c | 15 +++++++++++++--
 1 file changed, 13 insertions(+), 2 deletions(-)

diff --git a/gsk/gskrenderer.c b/gsk/gskrenderer.c
index 319954c..d4d8878 100644
--- a/gsk/gskrenderer.c
+++ b/gsk/gskrenderer.c
@@ -54,6 +54,9 @@
 #ifdef GDK_WINDOWING_WAYLAND
 #include <gdk/wayland/gdkwayland.h>
 #endif
+#ifdef GDK_WINDOWING_ANDROID
+#include <gdk/android/gdkandroid.h>
+#endif
 #ifdef GDK_WINDOWING_BROADWAY
 #include "broadway/gskbroadwayrenderer.h"
 #endif
@@ -635,16 +638,24 @@ vulkan_supported_platform (GdkSurface *surface,
   VkPhysicalDeviceProperties props;
   GError *error = NULL;
   gboolean platform_is_wayland;
+  gboolean platform_is_android;
 
 #ifdef GDK_WINDOWING_WAYLAND
   platform_is_wayland = GDK_IS_WAYLAND_DISPLAY (display);
 #else
   platform_is_wayland = FALSE;
 #endif
+#ifdef GDK_WINDOWING_ANDROID
+  /* Android always composites and the backend has a single fullscreen surface,
+   * so (like Wayland) Vulkan can be the primary renderer rather than fallback. */
+  platform_is_android = GDK_IS_ANDROID_DISPLAY (display);
+#else
+  platform_is_android = FALSE;
+#endif
 
-  if (!platform_is_wayland && !as_fallback)
+  if (!platform_is_wayland && !platform_is_android && !as_fallback)
     {
-      GSK_DEBUG (RENDERER, "Not using Vulkan: platform is not Wayland");
+      GSK_DEBUG (RENDERER, "Not using Vulkan: platform is not Wayland or Android");
       return FALSE;
     }
 
-- 
